# Supabase Storage (output cache).
# If unset, the API still works: it streams processed bytes directly (X-Cache: BYPASS).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=processed-media

# Safety limits (optional, defaults shown)
# MAX_IMAGE_BYTES=20971520        # 20 MB source image cap
# MAX_VIDEO_BYTES=52428800        # 50 MB source video cap
# FETCH_TIMEOUT_MS=15000          # source download timeout

# Allow fetching from private/loopback hosts (ONLY for local development/tests)
# SSRF_ALLOW_PRIVATE=true

# Per-IP rate limits (optional, generous defaults shown). Best-effort, in-memory.
# RATE_LIMIT_WINDOW_MS=60000       # window length
# RATE_LIMIT_PROCESS=100           # GET /api/process requests per window
# RATE_LIMIT_VIDEO=30              # GET /api/video/thumbnail requests per window
# RATE_LIMIT_CHAT=20               # POST /api/chat requests per window

# Assistant chatbot (optional). Without it, the chat widget shows a graceful
# "email me" fallback instead of answering. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-...
